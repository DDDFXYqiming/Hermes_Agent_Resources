# Runtime environment for the current zero-pip video_to_notes.py script.
# Copy to VIDEO_NOTES_RUNTIME_DIR\.env or point VIDEO_NOTES_ENV to this file.

# Optional helper paths. Leave empty when yt-dlp/ffmpeg are on PATH.
YTDLP=
FFMPEG=

# Optional whisper.cpp path/model used when --transcribe is passed or selected internally.
WHISPER_CPP=
WHISPER_MODEL=base

# Script behavior.
TRANSCRIBER_TYPE=faster-whisper
VIDEO_NOTES_TRANSCRIPT_CHUNK_CHARS=3200
VIDEO_NOTES_TRANSCRIPT_PREVIEW_CHARS=1200
VIDEO_NOTES_MAX_AGENT_FRAMES=3
VIDEO_NOTES_FRAME_MAX_WIDTH=640
